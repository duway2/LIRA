# ==============================
# LIRA SERVER ENV (backend)
# Save as: /var/www/html/lira/backend/.env
# ==============================

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=lira_user
DB_PASSWORD=change-me
DB_NAME=lira_db

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

PORT=8080
JWT_SECRET=replace-with-long-random-secret
FRONTEND_URL=https://lira-indonesia.org

# Midtrans (use production keys in production)
MIDTRANS_SERVER_KEY=Mid-server-xxxx
MIDTRANS_CLIENT_KEY=Mid-client-xxxx

# Google SSO
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://lira-indonesia.org/api/v1/auth/google/callback

# Brevo Email
BREVO_API_KEY=
EMAIL_FROM=noreply@lira-indonesia.org
EMAIL_FROM_NAME="LIRA Indonesia"

# Upload folder on server
UPLOAD_DIR=/var/www/html/lira/backend/uploads
