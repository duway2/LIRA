# ==============================
# LIRA SAMPLE ENV (backend)
# Copy to .env for local run
# ==============================

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=lira_db

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

PORT=8080
JWT_SECRET=replace-with-strong-secret
FRONTEND_URL=http://localhost:3000

# Midtrans
MIDTRANS_SERVER_KEY=SB-Mid-server-xxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxx

# Google SSO
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# Brevo Email
BREVO_API_KEY=
EMAIL_FROM=noreply@lira-indonesia.org
EMAIL_FROM_NAME="LIRA Indonesia"

# Upload folder
UPLOAD_DIR=./backend/uploads
